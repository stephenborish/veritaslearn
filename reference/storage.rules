rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Teacher-owned stimulus images: readable by any authenticated user,
    // writable only by authenticated users (proxied via server.ts upload endpoint).
    match /images/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Stimulus content uploaded by teacher accounts
    match /stimuli/{teacherUid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == teacherUid;
    }

    // System canary files used by server.ts at startup — server service account only
    match /_system/{allPaths=**} {
      allow read, write: if false;
    }

    // Default: deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

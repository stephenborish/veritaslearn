rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Strictly Default-Deny Catch-All)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives & Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function emailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Teacher check: role must come from the user document in Firestore, not from email patterns.
    // Never use email text patterns (+teacher, faculty, personal addresses) as teacher authorization.
    function isTeacher() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. Users collection
    // Students can read their own profile. Teachers can read all. Only the user or teacher can write.
    match /users/{userId} {
      allow read: if isOwner(userId) || isTeacher();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isOwner(userId) || isTeacher();
      allow delete: if isTeacher();
    }

    // 2. Courses collection — teachers read/write, students cannot access directly
    match /courses/{courseId} {
      allow read: if isTeacher();
      allow write: if isTeacher();
    }

    // 2b. Enrollments — students can read their own; teachers read/write all.
    // Students CANNOT create enrollments client-side; enrollment goes through the API server.
    match /enrollments/{enrollmentId} {
      allow read: if isTeacher() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow write: if isTeacher();
    }

    // 3. Lessons collection — teachers read/write all; students can read published lessons only
    match /lessons/{lessonId} {
      allow read: if isTeacher() || (isSignedIn() && resource.data.isPublished == true);
      allow write: if isTeacher();
    }

    // 4. Lesson Blocks — teacher only.
    // Students access lesson content through sanitized server routes (/api/lessons/:id),
    // not via direct Firestore reads, so direct student access is intentionally denied.
    // This prevents students from reading raw blocks containing answer keys, rubrics,
    // model answers, and other teacher-only fields.
    match /blocks/{blockId} {
      allow read: if isTeacher();
      allow write: if isTeacher();
    }

    // 5. Lesson Attempts — students own their attempts; teachers read all
    match /attempts/{attemptId} {
      allow read: if isTeacher() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if isTeacher() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow delete: if isTeacher();
    }

    // 6. Question Assignments (deterministic randomized question sets per attempt)
    // Students can read their own question assignments; teachers read all.
    // Students cannot read the teacher-only fields (correctChoiceId etc.) — those are excluded server-side.
    match /questionAssignments/{assignmentId} {
      allow read: if isTeacher() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }

    // Legacy: assignments collection (used by current code for question assignments)
    match /assignments/{assignmentId} {
      allow read: if isTeacher() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }

    // 7. Student Responses — students own their responses; teachers read all for grading
    match /responses/{responseId} {
      allow read: if isTeacher() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      // Students can only update their own unsubmitted responses (draft saves)
      allow update: if isTeacher() || (isSignedIn() && resource.data.studentId == request.auth.uid && resource.data.submittedAt == null);
      allow delete: if isTeacher();
    }

    // 8. Integrity Signals — students can create signals for their own attempts; teachers read/manage all
    // Students cannot edit or delete signals once created.
    match /integritySignals/{signalId} {
      allow read: if isTeacher();
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isTeacher();
    }

    // Legacy: securitySignals collection (used by current code)
    match /securitySignals/{signalId} {
      allow read: if isTeacher();
      allow create: if isSignedIn();
      allow update, delete: if isTeacher();
    }

    // 9. AI Grading Records — teacher-only; students cannot read AI grading internals
    // unless feedback has been explicitly released (feedbackReleasedAt is set).
    match /aiGradingRecords/{recordId} {
      allow read: if isTeacher() ||
        (isSignedIn() && resource.data.feedbackReleasedAt != null &&
         exists(/databases/$(database)/documents/responses/$(resource.data.responseId)) &&
         get(/databases/$(database)/documents/responses/$(resource.data.responseId)).data.studentId == request.auth.uid);
      allow write: if isTeacher();
    }

    // 10. Lesson Assignments (teacher-created assignment records) — teachers write; students read only via API.
    // Direct student reads are allowed here so offline-capable clients can cache; the server still
    // filters to enrolled courses before delivering the payload.
    match /lessonAssignments/{assignmentId} {
      allow read: if isTeacher() || isSignedIn();
      allow write: if isTeacher();
    }

    // 11. Gradebook Entries — teacher read/write; student can read their own entry
    match /gradebookEntries/{entryId} {
      allow read: if isTeacher() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow write: if isTeacher();
    }

    // 11. Audit Logs — teacher/admin read; system writes only (no client writes)
    match /auditLogs/{logId} {
      allow read: if isTeacher();
      allow write: if false;
    }
  }
}

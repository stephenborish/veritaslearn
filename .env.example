# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The full URL where this application is hosted.
# Used for self-referential links, OAuth callbacks, and CORS policy.
# Example: https://learn.veritas.courses
APP_URL="https://learn.veritas.courses"

# PUBLIC_APP_URL: The publicly-reachable URL for the frontend.
# Typically the same as APP_URL unless frontend and backend are on separate hosts.
PUBLIC_APP_URL="https://learn.veritas.courses"

# ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins.
# Add localhost entries for local development only.
# Example: https://learn.veritas.courses,http://localhost:3000
ALLOWED_ORIGINS="https://learn.veritas.courses"

# GOOGLE_ALLOWED_DOMAIN: School Google Workspace domain for authentication.
# Only users with emails ending in this domain can sign in.
# Set to empty string to allow any Google account (not recommended for production).
GOOGLE_ALLOWED_DOMAIN="malvernprep.org"

# TEACHER_EMAILS: Comma-separated list of email addresses that receive teacher role.
# All other authenticated users receive student role.
# Example: teacher1@malvernprep.org,teacher2@malvernprep.org
TEACHER_EMAILS="stephenborish@gmail.com"

# AI_GRADING_MODEL: Gemini model to use for AI short-answer grading.
# Defaults to gemini-2.0-flash if not set.
AI_GRADING_MODEL="gemini-2.0-flash"

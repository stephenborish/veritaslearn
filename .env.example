# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://learn.veritas.courses"

# GOOGLE_ALLOWED_DOMAIN: Restriction of student and teacher emails to a specific school Google Workspace domain.
# Set to '*' to allow any domain, or omit to default to 'malvernprep.org'.
GOOGLE_ALLOWED_DOMAIN="malvernprep.org"

# TEACHER_EMAILS: Comma-separated list of pre-approved Gmail addresses that are automatically assigned the 'teacher' admin role.
TEACHER_EMAILS="stephenborish@gmail.com"

# AI_GRADING_MODEL: The Gemini model used for conducting asynchronous short answer scoring and rubric-based feedback.
# Supported choices: gemini-2.0-flash, gemini-2.0-pro-exp-02-05, etc. Defaults to 'gemini-2.0-flash'.
AI_GRADING_MODEL="gemini-2.0-flash"

# AUTHORIZED_STUDENT_EMAILS: Comma-separated exact external student emails allowed to sign in as students for temporary testing. Does not grant teacher access. Remove when no longer needed.
AUTHORIZED_STUDENT_EMAILS=""


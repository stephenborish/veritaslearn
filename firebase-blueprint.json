{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profiles for teachers and students",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "student"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "createdAt"]
    },
    "Course": {
      "title": "Course",
      "description": "Educational courses configured in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "teacherId": { "type": "string" },
        "code": { "type": "string" }
      },
      "required": ["id", "name", "teacherId", "code"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "High-level lesson configuration parameters and controls",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "courseId": { "type": "string" },
        "estimatedMinutes": { "type": "number" },
        "isPublished": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "description", "courseId", "estimatedMinutes", "isPublished", "createdAt"]
    },
    "LessonBlock": {
      "title": "LessonBlock",
      "description": "Sequential structural segments belonging to a lesson",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "lessonId": { "type": "string" },
        "order": { "type": "number" },
        "type": { "type": "string", "enum": ["video", "reading", "question"] },
        "title": { "type": "string" },
        "videoUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "storagePath": { "type": "string" },
        "duration": { "type": "number" }
      },
      "required": ["id", "lessonId", "order", "type", "title"]
    },
    "LessonAttempt": {
      "title": "LessonAttempt",
      "description": "Active or completed attempt session by a student",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "lessonId": { "type": "string" },
        "studentId": { "type": "string" },
        "seed": { "type": "number" },
        "startedAt": { "type": "string" },
        "completedAt": { "type": "string" },
        "status": { "type": "string", "enum": ["started", "completed"] },
        "currentBlockIndex": { "type": "number" },
        "activeTimeSpent": { "type": "number" },
        "inactiveTimeSpent": { "type": "number" }
      },
      "required": ["id", "lessonId", "studentId", "seed", "startedAt", "status", "currentBlockIndex", "activeTimeSpent", "inactiveTimeSpent"]
    },
    "QuestionAssignment": {
      "title": "QuestionAssignment",
      "description": "Assigned questions initialized from a specific attempt seed",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "attemptId": { "type": "string" },
        "blockId": { "type": "string" },
        "checkpointId": { "type": "string" },
        "questionId": { "type": "string" }
      },
      "required": ["id", "attemptId", "blockId", "questionId"]
    },
    "StudentResponse": {
      "title": "StudentResponse",
      "description": "Student generated answer submissions for multiple choice or short answer questions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "attemptId": { "type": "string" },
        "studentId": { "type": "string" },
        "blockId": { "type": "string" },
        "checkpointId": { "type": "string" },
        "questionId": { "type": "string" },
        "type": { "type": "string", "enum": ["mc", "sa"] },
        "score": { "type": "number" },
        "activeTimeSpent": { "type": "number" }
      },
      "required": ["id", "attemptId", "studentId", "blockId", "questionId", "type", "score", "activeTimeSpent"]
    },
    "SecuritySignal": {
      "title": "SecuritySignal",
      "description": "Logs tracking security and focus events generated during play tests",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "attemptId": { "type": "string" },
        "studentId": { "type": "string" },
        "timestamp": { "type": "string" },
        "eventType": { "type": "string" },
        "severity": { "type": "string" },
        "blockId": { "type": "string" },
        "videoTimestamp": { "type": "number" }
      },
      "required": ["id", "attemptId", "studentId", "timestamp", "eventType", "severity"]
    },
    "AIGradingRecord": {
      "title": "AIGradingRecord",
      "description": "Historical AI evaluations and scoring breakdowns for short answers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "responseId": { "type": "string" },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "promptVersion": { "type": "string" },
        "parsedScore": { "type": "number" },
        "confidence": { "type": "number" },
        "rationale": { "type": "string" },
        "status": { "type": "string" },
        "gradedAt": { "type": "string" }
      },
      "required": ["id", "responseId", "parsedScore", "confidence", "status"]
    },
    "GradebookEntry": {
      "title": "GradebookEntry",
      "description": "Overall attempt-level grading summary for a student's lesson assignment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "assignmentId": { "type": "string" },
        "rawScore": { "type": "number" },
        "finalScore": { "type": "number" },
        "maxPoints": { "type": "number" },
        "percent": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "studentId", "assignmentId", "finalScore", "maxPoints", "status"]
    },
    "GradebookResponseEntry": {
      "title": "GradebookResponseEntry",
      "description": "Detailed question-by-question evaluation record of student responses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "attemptId": { "type": "string" },
        "responseId": { "type": "string" },
        "score": { "type": "number" },
        "maxScore": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "studentId", "attemptId", "responseId", "score", "maxScore", "status"]
    },
    "ApprovedTeacher": {
      "title": "ApprovedTeacher",
      "description": "Dynamic roster list of verified teachers approved by the system super admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "addedBy": { "type": "string" },
        "addedAt": { "type": "string" }
      },
      "required": ["id", "email", "addedBy", "addedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Roster of authenticated classroom participants"
    },
    "courses/{courseId}": {
      "schema": "Course",
      "description": "Active classrooms and course subjects"
    },
    "lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Available syllabus curricula assessments"
    },
    "blocks/{blockId}": {
      "schema": "LessonBlock",
      "description": "Ordered segment chunks for video streams, readings, or quizzes"
    },
    "attempts/{attemptId}": {
      "schema": "LessonAttempt",
      "description": "Student workspace session state"
    },
    "assignments/{assignmentId}": {
      "schema": "QuestionAssignment",
      "description": "Scrambled question variants deterministically assigned to a student's attempt to deter sharing"
    },
    "responses/{responseId}": {
      "schema": "StudentResponse",
      "description": "Student submitted answers evaluated dynamically by auto-grader or rubric-matched AI"
    },
    "securitySignals/{signalId}": {
      "schema": "SecuritySignal",
      "description": "Integrity signals / activity records: copy-paste blocks, focus events, fullscreen changes, or seek attempts"
    },
    "aiGradingRecords/{recordId}": {
      "schema": "AIGradingRecord",
      "description": "AI grading records for teacher verification and review of short answer responses"
    },
    "gradebookEntries/{entryId}": {
      "schema": "GradebookEntry",
      "description": "Durable high-level grades per lesson assignment and student"
    },
    "gradebookResponseEntries/{entryId}": {
      "schema": "GradebookResponseEntry",
      "description": "Durable answer scores tracking correctness per student response"
    },
    "approvedTeachers/{teacherId}": {
      "schema": "ApprovedTeacher",
      "description": "Dynamic list of verified teachers approved by system super admin"
    }
  }
}